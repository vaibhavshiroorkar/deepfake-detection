# Comma-separated list of allowed frontend origins. Use * during local dev.
ALLOWED_ORIGINS=http://localhost:3000

# Supabase project: Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role
# Project Settings → API → JWT Settings → JWKS — paste the full JWK JSON as one line
SUPABASE_JWT_PUBLIC_KEY={"x":"...","y":"...","alg":"ES256","crv":"P-256","kty":"EC","key_ops":["verify"],"kid":"..."}

# Phase 2 — Trained model weights (set after running training scripts)
# See training/README.md for instructions.
# VERITAS_DINOV2_WEIGHTS=/absolute/path/to/weights/dinov2_head.pt
# VERITAS_WHISPER_WEIGHTS=/absolute/path/to/weights/whisper_head.pt
# VERITAS_TEMPORAL_WEIGHTS=/absolute/path/to/weights/temporal_transformer.pt

# Force CPU even when CUDA is available (for low-RAM hosts)
# VERITAS_FORCE_CPU=1

# Override the fallback image classifier (default: Organika/sdxl-detector)
# VERITAS_AI_IMAGE_MODEL=Organika/sdxl-detector
